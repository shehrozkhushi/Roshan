# Optional local fallback used only when MONGODB_URI is not configured.
# The default is data/contact-submissions.local.json.
CONTACT_STORAGE_PATH=

# Optional: public production URL used for canonical metadata and sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB Atlas connection string. Keep the real value in .env.local or your
# deployment platform's secret environment variables.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.example.mongodb.net/DATABASE
MONGODB_DB=roshan_studio

# Production origin used to reject cross-site authentication requests.
APP_ORIGIN=http://localhost:3000

# Gmail SMTP credentials. Use a Google App Password, not the account password.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional contact notification recipient. Defaults to GMAIL_USER.
CONTACT_TO_EMAIL=contact@example.com

# Server-only HMAC secret used to protect signup verification codes.
# Generate one with: openssl rand -hex 32
AUTH_VERIFICATION_SECRET=replace-with-a-random-64-character-hex-value
